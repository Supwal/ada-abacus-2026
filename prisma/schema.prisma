generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["driverAdapters"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  firstName     String?   @map("first_name")
  lastName      String?   @map("last_name")
  phone         String?
  profession    String?
  emailVerified DateTime? @map("email_verified")
  image         String?
  hashedPassword String?  @map("hashed_password")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  locations      Location[]
  services       Service[]
  clients        Client[]
  appointments   Appointment[]
  earnings       Earning[]
  expenses       Expense[]
  agendaStatus   AgendaStatus?
  availabilities Availability[]
  packs          Pack[]
  subscription   Subscription?
  payments       Payment[]

  @@map("users")
}

model Location {
  id          String   @id
  name        String
  address     String?
  description String?
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments   Appointment[]
  earnings       Earning[]
  availabilities Availability[]

  @@map("locations")
}

model Service {
  id          String   @id
  name        String
  duration    Int      // em minutos
  price       Float
  description String?
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  earnings     Earning[]

  @@map("services")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  notes     String?
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  earnings     Earning[]

  @@map("clients")
}

model Appointment {
  id          String   @id @default(cuid())
  date        DateTime
  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  status      String   @default("scheduled") // scheduled, completed, cancelled
  notes       String?
  value       Float?
  paid        Boolean  @default(false)
  userId      String   @map("user_id")
  clientId    String   @map("client_id")
  serviceId   String   @map("service_id")
  locationId  String   @map("location_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("appointments")
}

model Earning {
  id            String   @id @default(cuid())
  description   String
  amount        Float
  date          DateTime
  userId        String   @map("user_id")
  clientId      String?  @map("client_id")
  serviceId     String?  @map("service_id")
  locationId    String?  @map("location_id")
  appointmentId String?  @unique @map("appointment_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  service  Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@map("earnings")
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  expenses  Expense[]

  @@map("expense_categories")
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  date        DateTime
  userId      String   @map("user_id")
  categoryId  String   @map("category_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@map("expenses")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model AgendaStatus {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  isOpen    Boolean  @default(true) @map("is_open")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agenda_status")
}

model Availability {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  type              String   // "dia", "semana", "meio_periodo"
  date              DateTime @map("date")
  startTime         String   @map("start_time")
  endTime           String   @map("end_time")
  locationId        String   @map("location_id")
  hourlyRate        Float    @map("hourly_rate")
  maxAppointments   Int      @map("max_appointments")
  notes             String?
  notificationChannel String @map("notification_channel") // "whatsapp", "telegram"
  currentAppointments Int    @default(0) @map("current_appointments")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("availabilities")
}

model Pack {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  photos      Int      // quantidade de fotos
  videos      Int      // quantidade de vídeos
  price       Float    // preço do pack
  coverImage  String?  @map("cover_image") // URL da imagem de capa
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("packs")
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  planType      String   // "basico" ou "completo"
  price         Float    // 29.90 ou 79.90
  status        String   @default("ativo") // "ativo", "cancelado", "expirado"
  startDate     DateTime @default(now()) @map("start_date")
  endDate       DateTime? @map("end_date")
  voiceEnabled  Boolean  @default(true) @map("voice_enabled") // se plano inclui voz
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Payment {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  asaasPaymentId      String   @map("asaas_payment_id") // ID do pagamento no Asaas
  planType            String   // "basico" ou "completo"
  price               Float
  status              String   @default("pending") // "pending", "CONFIRMED", "FAILED", "CANCELLED"
  billingType         String   // "PIX", "BOLETO", "CREDIT_CARD", "DEBIT_CARD"
  externalReference   String?  @map("external_reference")
  bankSlipUrl         String?  @map("bank_slip_url")
  pixQrCode           String?  @map("pix_qr_code")
  invoiceUrl          String?  @map("invoice_url")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}
